# DB 비밀번호
MARIADB_ROOT_PASSWORD=
MARIADB_PASSWORD=
CARGOUSER_PASSWORD=

# 미디어위키 $wgServer 변수에 들어갈 사이트 주소 
WG_SERVER=
WG_SECRET_KEY=

# SMTP 설정
SMTP_PASSWORD=

# QuestyCaptcha 답변
CAPTCHA_ANSWERS=

# Google API 키
GOOGLE_API_KEY=

# Cloudflare Turnstile 키
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# 개발용 포트 (설정하지 않으면 기본값으로 10597이 사용됩니다.)
DEV_SERVICE_PORT=

# Backblaze B2 백업용
# B2 애플리케이션 키(B2_KEY_ID, B2_KEY)와 버킷 이름(B2_BUCKET_NAME)이 필요합니다.
# B2_BUCKET_PATH: 버킷 내 경로 (예: /db-backup, 비워두면 버킷 루트)
# MAX_DAILY_BACKUPS: 보관할 일간 백업 개수 (초과분 자동 삭제)
MAX_DAILY_BACKUPS=7
B2_KEY_ID=
B2_KEY=
B2_BUCKET_NAME=
B2_BUCKET_PATH=

# 페이지 덤프 백업용
## BACKUP_PAGES_GITHUB_REPO: 페이지 백업용 Github 리포지토리, 프로덕션에서는 현재 `ChangpopWiki/dump` 입니다.
## 개발 환경에서는 별도의 테스트용 리포지토리를 사용해주세요. 실수로 백업이 덮어쓰여질 수 있습니다.
BACKUP_PAGES_GITHUB_APP_ID=4322142
BACKUP_PAGES_GITHUB_INSTALLATION_ID=147155962
BACKUP_PAGES_GITHUB_REPO=
